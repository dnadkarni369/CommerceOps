{
  "title": "CommerceOps - Services Overview",
  "uid": "commerceops-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Service (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(api_requests_total[1m])) by (endpoint)", "legendFormat": "api {{endpoint}}" },
        { "expr": "sum(rate(auth_requests_total[1m])) by (endpoint)", "legendFormat": "auth {{endpoint}}" },
        { "expr": "sum(rate(order_requests_total[1m])) by (endpoint)", "legendFormat": "order {{endpoint}}" },
        { "expr": "sum(rate(ai_requests_total[1m])) by (endpoint)", "legendFormat": "ai {{endpoint}}" }
      ]
    },
    {
      "id": 2,
      "title": "Orders Created (total)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "orders_created_total" }]
    },
    {
      "id": 3,
      "title": "Worker: Processed vs Failed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "rate(worker_orders_processed_total[1m])", "legendFormat": "processed" },
        { "expr": "rate(worker_orders_failed_total[1m])", "legendFormat": "failed" }
      ]
    },
    {
      "id": 4,
      "title": "Recommendation Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(ai_cache_hits_total[1m])", "legendFormat": "hits" },
        { "expr": "rate(ai_cache_misses_total[1m])", "legendFormat": "misses" }
      ]
    },
    {
      "id": 5,
      "title": "Upstream Errors (gateway)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(api_upstream_errors_total[1m])) by (upstream)", "legendFormat": "{{upstream}}" }
      ]
    },
    {
      "id": 6,
      "title": "Node CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "{{instance}}" }
      ]
    },
    {
      "id": 7,
      "title": "Postgres Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "connections" }
      ]
    }
  ]
}
