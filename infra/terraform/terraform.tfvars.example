aws_region   = "ap-south-1"
project_name = "commerceops"
environment  = "dev"

# Free-tier sizing - do not increase without checking your usage
instance_type    = "t3.micro"
db_instance_class = "db.t3.micro"

asg_min_size         = 1
asg_max_size         = 2
asg_desired_capacity = 1

# Set this via TF_VAR_db_password instead of committing it here
# db_password = "changeme"

key_pair_name = "commerceops-key"
